{
  "_comment": "OpenClaw uses OpenViking as contextEngine through the enhanced plugin, not through CLI hooks. Configure via: openclaw config set",
  "_note": "The legacy native openviking plugin should stay disabled when openviking-enhanced is selected.",
  "enabled": true,
  "config": {
    "agentId": "YOUR_AGENT_ID",
    "recallLimit": 10,
    "scoreThreshold": 0.1
  },
  "_env_vars": {
    "OPENVIKING_URL": "http://127.0.0.1:1933",
    "OPENVIKING_API_KEY": "your-bearer-token",
    "OPENVIKING_ACCOUNT": "YOUR_ACCOUNT",
    "OPENVIKING_USER": "YOUR_USER",
    "OPENVIKING_AGENT_PREFIX": "openclaw"
  },
  "_slots": {
    "contextEngine": "openviking-enhanced"
  },
  "_legacy_native_plugin": {
    "plugins.entries.openviking.enabled": false
  },
  "_dreaming": {
    "_comment": "Dreaming is configured via memory-core plugin, not OV plugin",
    "path": "plugins.entries.memory-core.config.dreaming",
    "enabled": true,
    "phases": {
      "deep": {
        "minRecallCount": 1,
        "minUniqueQueries": 1,
        "minScore": 0.5,
        "recencyHalfLifeDays": 7
      }
    }
  }
}

{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/auto-recall.mjs",
            "timeout": 8000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/auto-capture.mjs",
            "timeout": 45000
          }
        ]
      }
    ]
  }
}

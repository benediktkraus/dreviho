{
  "personal_projects": [],
  "infra_patterns": ["docker", "infra", "monitoring"],
  "project_base_paths": [],
  "scopes": {
    "system": {
      "uri_prefix": "viking://resources/system/",
      "always_active": true,
      "tier": "holy"
    },
    "infra": {
      "uri_prefix": "viking://resources/infra/",
      "always_active": false,
      "tier": "holy"
    },
    "knowledge": {
      "uri_prefix": "viking://resources/knowledge/",
      "always_active": true,
      "tier": "volatile",
      "hint": "Contains: API directories, research outputs, external docs. Search here for APIs, tools, external resources."
    },
    "personal": {
      "uri_prefix": "viking://user/memories/personal/",
      "always_active": false,
      "tier": "holy"
    }
  },
  "source_authority": {
    "user_verified": 2.0,
    "user_input": 1.5,
    "agent_verified": 1.2,
    "auto_captured": 1.0,
    "verified_recall_threshold": 5
  },
  "mmr": {
    "enabled": true,
    "lambda": 0.7
  },
  "decay": {
    "enabled": true,
    "halfLifeDays": 90,
    "memoryMaxAgeDays": 180,
    "evergreen": ["viking://resources/"]
  },
  "compaction": {
    "enabled": true,
    "strategy": "caveman",
    "strip_code_blocks": true,
    "strip_tables": true,
    "collapse_whitespace": true
  }
}
